  <property name="styleSheet">
   <string notr="true">QLineEdit {
    color: #e0e6f0; /* light gray text for dark bg */
    font-size: 14px;
    background-color: rgba(255, 255, 255, 0.05); /* slightly visible bg for input field */
    padding: 6px;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2); /* soft light line before focus */
    border-radius: 4px;
}

QLineEdit:hover {
    background-color: rgba(255, 255, 255, 0.1); /* slightly brighter on hover */
}

QLineEdit:focus {
    outline: none;
    border-bottom: 2px solid #5891ff; /* bright blue focus line */
    background-color: rgba(255, 255, 255, 0.12);
}

QLabel {
    border: 1px solid white;   /* White border */
    border-radius: 6px;        /* Rounded corners (optional) */
    padding: 4px;              /* Space inside */
}

QWidget { 
	background-color: #2b3640;
}

QPushButton {
    color: #e0e6f0; /* light text */
    font-size: 14px;
    background-color: #2e3a4b; /* dark gray-blue button */
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    padding: 6px 14px;
}

QPushButton:hover {
    background-color: #3c4d63; /* lighter on hover */
    border: 1px solid #5891ff; /* subtle blue glow */
}

QPushButton:pressed {
    background-color: #1e2a3a; /* darker when pressed */
    border: 1px solid #4f7de0;
}

QPushButton:disabled {
    color: rgba(255, 255, 255, 0.4);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

QComboBox {
    color: #e0e6f0; /* light text */
    font-size: 14px;
    background-color: rgba(255, 255, 255, 0.05); /* subtle transparent bg */
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    padding: 6px 10px;
}

QComboBox:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid #5891ff; /* subtle blue border */
}

QComboBox:focus {
    border: 1px solid #5891ff;
    background-color: rgba(255, 255, 255, 0.12);
    outline: none;
}

/* ▼ Dropdown arrow */
QComboBox::drop-down {
    border: none;
    width: 25px;
    background-color: transparent;
}

QComboBox::down-arrow {
    image: url(:/icons/Icons/sort_by.png); /* replace with your icon */
    width: 20px;
    height: 20px;
}

/* Popup (the dropdown list) */
QComboBox QAbstractItemView {
    background-color: #2e3a4b; /* darker popup background */
    color: #e0e6f0;
    border: 1px solid #5891ff;
    selection-background-color: #3c4d63; /* selected item background */
    selection-color: #ffffff;
}

QDialog {
   color: white;
   border: none;
}

QDialog QLabel {
    color: white;
    border: none;
}


QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 8px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: rgba(255, 255, 255, 0.2);
    min-height: 30px;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(255, 255, 255, 0.3);
}

QScrollBar::handle:vertical:pressed {
    background: rgba(255, 255, 255, 0.4);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
    height: 0px;
}

/* Horizontal */
QScrollBar:horizontal {
    border: none;
    background: transparent;
    height: 8px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background: rgba(255, 255, 255, 0.2);
    min-width: 30px;
    border-radius: 4px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(255, 255, 255, 0.3);
}

QScrollBar::handle:horizontal:pressed {
    background: rgba(255, 255, 255, 0.4);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
    width: 0px;
}

