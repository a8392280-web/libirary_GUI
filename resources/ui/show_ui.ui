  <property name="styleSheet">
   <string notr="true">/* ===== SCROLL AREAS &amp; CONTAINERS ===== */
QScrollArea, QStackedWidget,
QWidget#scroll_content, 
QWidget#info_scrollarea,
QWidget#scroll_content_2, 
QWidget#info_scrollarea_2 {
    background-color: #182126;
    border: none;
}

QWidget#show {
    background-color: #262e39;
}

/* ===== BASE TEXT STYLES ===== */
QLabel, QLineEdit, QPushButton, QComboBox {
    color: #e0e6f0;
    font-size: 14px;
    background-color: transparent;
}

/* ===== INPUT FIELDS ===== */
QLineEdit {
    background-color: rgba(255, 255, 255, 0.05);
    padding: 6px;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
}

QLineEdit:hover {
    background-color: rgba(255, 255, 255, 0.1);
}

QLineEdit:focus {
    border-bottom: 2px solid #5891ff;
    background-color: rgba(255, 255, 255, 0.12);
    outline: none;
}

/* ===== BUTTONS ===== */
QPushButton {
    background-color: #2e3a4b;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    padding: 6px 14px;
}

QPushButton:hover {
    background-color: #3c4d63;
    border: 1px solid #5891ff;
}

QPushButton:pressed {
    background-color: #1e2a3a;
    border: 1px solid #4f7de0;
}

QPushButton:disabled {
    color: rgba(255, 255, 255, 0.4);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
}

/* ===== COMBO BOXES ===== */
QComboBox {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    padding: 6px 10px;
}

QComboBox:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid #5891ff;
}

QComboBox:focus {
    border: 1px solid #5891ff;
    background-color: rgba(255, 255, 255, 0.12);
    outline: none;
}

QComboBox::drop-down {
    border: none;
    width: 25px;
    background-color: transparent;
}

QComboBox::down-arrow {
    image: url(:/icons/Icons/sort_by.png);
    width: 20px;
    height: 20px;
}

QComboBox QAbstractItemView {
    background-color: #2e3a4b;
    color: #e0e6f0;
    border: 1px solid #5891ff;
    selection-background-color: #3c4d63;
    selection-color: #ffffff;
}

/* ===== TABS ===== */
QTabWidget::pane {
    border: none;
    background: transparent;
}

QTabBar {
    qproperty-drawBase: 0;
    alignment: center;
}

QTabBar::tab {
    background: transparent;
    color: #6d747e;
    padding: 10px 25px;
    margin: 0px 5px;
    font: 13pt &quot;Segoe UI&quot;;
    border-bottom: 3px solid transparent;
}

QTabBar::tab:selected {
    color: #cad1d9;
    border-bottom: 3px solid #fbffff;
}

QTabBar::tab:hover {
    color: #cad1d9;
}

/* ===== LABELS ===== */
QLabel#show_image_lable {
    border: none;
    border-radius: 6px;
    padding: 4px;
}

QDialog {
    background-color:#182126;    /* your dark color */
    color: white;
}

QDialog QLabel {
    color: white;
}
</string>
